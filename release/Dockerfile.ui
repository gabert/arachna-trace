# syntax=docker/dockerfile:1.7
#
# Static UI: Vite-built Vue app served by nginx, with /api/ proxied to
# the query container. Build context: repo root.

# -------------------------------------------------------------------
# Build
# -------------------------------------------------------------------
FROM node:20-alpine@sha256:fb4cd12c85ee03686f6af5362a0b0d56d50c58a04632e6c0fb8363f609372293 AS builder
WORKDIR /src

# Cache dependencies on package.json changes only.
COPY arachna-trace-ui/package.json arachna-trace-ui/package-lock.json ./
RUN --mount=type=cache,target=/root/.npm \
    npm ci

COPY arachna-trace-ui/ ./
RUN npm run build

# -------------------------------------------------------------------
# Runtime
# -------------------------------------------------------------------
FROM nginx:1.27-alpine@sha256:65645c7bb6a0661892a8b03b89d0743208a18dd2f3f17a54ef4b76fb8e2f2a10
COPY release/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /src/dist /usr/share/nginx/html
EXPOSE 80
