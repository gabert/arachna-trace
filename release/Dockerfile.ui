# syntax=docker/dockerfile:1.7
#
# Static UI: Vite-built Vue app served by nginx, with /api/ proxied to
# the query container. Build context: repo root.

# -------------------------------------------------------------------
# Build
# -------------------------------------------------------------------
FROM node:20-alpine AS builder
WORKDIR /src

# Cache dependencies on package.json changes only.
COPY deepflow-ui/package.json deepflow-ui/package-lock.json ./
RUN --mount=type=cache,target=/root/.npm \
    npm ci

COPY deepflow-ui/ ./
RUN npm run build

# -------------------------------------------------------------------
# Runtime
# -------------------------------------------------------------------
FROM nginx:1.27-alpine
COPY release/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /src/dist /usr/share/nginx/html
EXPOSE 80
